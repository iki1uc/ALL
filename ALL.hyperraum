import { ALL_RESPO } from "./ALL.respo.js";

export function ALL_HYPERRAUM(){
    const out = {
        score: Math.random() * 999,
        deg: Math.floor(Math.random() * 360),
        vector: [Math.random(), Math.random(), Math.random()]
    };

    ALL_RESPO.add("hyperraum", out);
    return out;
}
